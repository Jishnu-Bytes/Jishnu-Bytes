// Global pointer for qsort to compare array elements by their indices
int* global_arr;

// Comparator function for qsort
int compare(const void *a, const void *b) {
    int idxA = *(int*)a;
    int idxB = *(int*)b;
    
    if (global_arr[idxA] < global_arr[idxB]) return -1;
    if (global_arr[idxA] > global_arr[idxB]) return 1;
    return 0;
}

int* arrayRankTransform(int* arr, int arrSize, int* returnSize) {
    *returnSize = arrSize;
    if (arrSize == 0) return NULL;

    int* result = (int*)malloc(arrSize * sizeof(int));
    int* indices = (int*)malloc(arrSize * sizeof(int));
    
    for (int i = 0; i < arrSize; i++) {
        indices[i] = i;
    }

    // Set global pointer right before calling qsort so it's fresh for every test case
    global_arr = arr;
    qsort(indices, arrSize, sizeof(int), compare);

    int rank = 1;
    result[indices[0]] = rank;

    for (int i = 1; i < arrSize; i++) {
        if (arr[indices[i]] > arr[indices[i - 1]]) {
            rank++;
        }
        result[indices[i]] = rank;
    }

    free(indices);
    return result;
}
