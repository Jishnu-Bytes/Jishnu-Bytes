#include <stdbool.h>
#include <string.h>

bool isValid(char* s) {
    int len = strlen(s);
    
    // An empty string is valid, but an odd length string can never be balanced
    if (len == 0) return true;
    if (len % 2 != 0) return false;
    
    // Allocate space for the stack (at most, it will hold len characters)
    char stack[len];
    int top = -1;
    
    for (int i = 0; i < len; i++) {
        char current = s[i];
        
        // If it's an opening bracket, push it onto the stack
        if (current == '(' || current == '[' || current == '{') {
            stack[++top] = current;
        } 
        // If it's a closing bracket
        else {
            // Stack is empty means there is no matching opening bracket
            if (top == -1) return false;
            
            char topChar = stack[top--];
            
            // Check for matching pairs
            if (current == ')' && topChar != '(') return false;
            if (current == ']' && topChar != '[') return false;
            if (current == '}' && topChar != '{') return false;
        }
    }
    
    // If the stack is empty, all brackets were matched perfectly
    return top == -1;
}
